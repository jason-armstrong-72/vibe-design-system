{
  "name": "vibe-design-system",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -n next,tokens -c blue,green \"next dev\" \"tsx scripts/watch-tokens.ts\"",
    "build": "next build",
    "start": "next start",
    "lint": "eslint app components lib scripts",
    "check": "tsx scripts/check.ts",
    "verify": "npm run check && npm run test && npm run lint && npm run build",
    "test": "vitest run",
    "tokens": "tsx scripts/generate-tokens.ts",
    "tokens:watch": "tsx scripts/watch-tokens.ts",
    "theme": "tsx scripts/apply-theme.ts",
    "e2e": "playwright test",
    "gallery": "GALLERY=1 playwright test e2e/gallery.spec.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "@untitled-ui/icons-react": "^0.1.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.20.0",
    "next": "16.2.9",
    "postcss": "^8.5.15",
    "radix-ui": "^1.6.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.11.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@tailwindcss/node": "^4.3.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/culori": "^4.0.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "chokidar": "^5.0.0",
    "concurrently": "^9.2.1",
    "culori": "^4.0.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "vitest": "^4.1.9"
  }
